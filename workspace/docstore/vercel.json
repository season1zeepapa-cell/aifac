{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/upload.js": { "maxDuration": 300, "supportsResponseStreaming": true },
    "api/search.js": { "maxDuration": 30 },
    "api/law.js": { "maxDuration": 30 },
    "api/law-import.js": { "maxDuration": 300, "supportsResponseStreaming": true },
    "api/rag.js": { "maxDuration": 60 },
    "api/summary.js": { "maxDuration": 300 },
    "api/url-import.js": { "maxDuration": 60 },
    "api/ocr.js": { "maxDuration": 60 },
    "api/documents.js": { "maxDuration": 300, "supportsResponseStreaming": true },
    "api/api-usage.js": { "maxDuration": 30 },
    "api/login.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
