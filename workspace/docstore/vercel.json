{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/upload.js": { "maxDuration": 300 },
    "api/search.js": { "maxDuration": 30 },
    "api/law.js": { "maxDuration": 30 },
    "api/law-import.js": { "maxDuration": 300 },
    "api/rag.js": { "maxDuration": 60 },
    "api/summary.js": { "maxDuration": 300 },
    "api/url-import.js": { "maxDuration": 60 },
    "api/ocr.js": { "maxDuration": 60 },
    "api/documents.js": { "maxDuration": 300 },
    "api/api-usage.js": { "maxDuration": 30 },
    "api/login.js": { "maxDuration": 10 },
    "api/cross-references.js": { "maxDuration": 120 },
    "api/knowledge-graph.js": { "maxDuration": 120 },
    "api/knowledge-graph-neo4j.js": { "maxDuration": 120 },
    "api/chat-sessions.js": { "maxDuration": 10 },
    "api/crawl-sources.js": { "maxDuration": 10 },
    "api/crawl-keywords.js": { "maxDuration": 10 },
    "api/naver-news.js": { "maxDuration": 30 },
    "api/crawl.js": { "maxDuration": 60 },
    "api/crawl-ingest.js": { "maxDuration": 300 },
    "api/pdf-loaders.js": { "maxDuration": 10 },
    "api/settings.js": { "maxDuration": 10 },
    "api/upload-url.js": { "maxDuration": 10 },
    "api/split-preview.js": { "maxDuration": 10 },
    "api/pdf-python.py": { "runtime": "@vercel/python@4.6.0", "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
